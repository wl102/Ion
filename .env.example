# ============================================================
# LLM API Configuration
# ============================================================

# OpenAI-compatible API base URL
OPENAI_BASE_URL = "https://api.openai.com/v1"

# API key for authentication
OPENAI_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Model identifier (e.g., gpt-4o, MiniMax-M2.7, claude-sonnet-4-6)
MODEL_ID = "gpt-4o"

# ============================================================
# Agent Loop Control
# ============================================================

# Maximum turns for the main agent loop (0 = unlimited)
AGENT_MAX_LOOP = 100

# Maximum turns for sub-agent delegation (used via Budget.max_turns, not an env var)
SUB_AGENT_MAX_LOOP = 50

# Context window token threshold; when exceeded, older history is compressed (0 = disabled)
CONTEXT_MAX_TOKENS = 128000

# ============================================================
# Persistence & Logging
# ============================================================

# Directory for session observability logs (.jsonl files)
# If omitted, defaults to ~/.ion/logs
ION_LOG_DIR = "./logs"

# Database connection URL.
# WARNING: SQLite URLs must use absolute paths with 4 slashes.
#   Correct: sqlite:////home/user/.ion/ion.db
#   Wrong:   sqlite:///~/.ion/ion.db   (SQLite does NOT expand ~)
# MySQL:    mysql+pymysql://user:pass@localhost/ion
# PostgreSQL: postgresql://user:pass@localhost/ion
# ION_DATABASE_URL = "sqlite:////home/user/.ion/ion.db"

# ============================================================
# Tool Configuration
# ============================================================

# Timeout for bash/shell command execution (seconds)
BASH_COMMAND_TIMEOUT = 120
